<UserControl x:Class="SilkySouls3.Views.UtilityTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:converters="clr-namespace:SilkySouls3.Converters"
             xmlns:gameIds="clr-namespace:SilkySouls3.GameIds"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="600">

    <UserControl.Resources>
        <converters:BooleanAndConverter x:Key="BooleanAndConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,5">
            <StackPanel Margin="10">
                <TextBlock Text="General" />

                <StackPanel Margin="0,5,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3" VerticalAlignment="Center">
                        <CheckBox Content="100% Drop"
                                  IsChecked="{Binding Is100DropEnabled}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,20,0" />
                        <Button Content="Break Objects"
                                Command="{Binding BreakAllObjectsCommand}"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Padding="5,3"
                                Margin="0,0,20,0" />
                        <Button Content="Restore Objects"
                                Command="{Binding RestoreAllObjectsCommand}"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Padding="5,3"
                                Margin="0,0,0,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                        <xctk:DoubleUpDown x:Name="SpeedUpDown"
                                           Value="{Binding GameSpeed}"
                                           TextAlignment="Center"
                                           Width="80"
                                           Minimum="0"
                                           Maximum="10"
                                           Increment="0.50"
                                           FormatString="F2"
                                           IsEnabled="{Binding AreOptionsEnabled}"
                                           BorderBrush="#3F3F46" />
                        <TextBlock Text="Game Speed" VerticalAlignment="Center" Margin="10,0,20,0" />
                        <CheckBox Content="Remember Speed"
                                  IsChecked="{Binding IsRememberSpeedEnabled}"
                                  VerticalAlignment="Center"/>
                        <Border
                            Background="#3498db"
                            CornerRadius="10"
                            Width="12"
                            Height="12"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Remember toggled speed across app restarts"
                            ToolTipService.InitialShowDelay="100">
                            <TextBlock Text="i"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="10" />
                        </Border>
                        <CheckBox Content="Freeze World"
                                  IsChecked="{Binding IsFreezeWorldEnabled}"
                                  Margin="20,0,0,0"
                                  VerticalAlignment="Center"
                                  IsEnabled="{Binding AreOptionsEnabled}" />
                        <Border
                            Background="#3498db"
                            CornerRadius="10"
                            Width="12"
                            Height="12"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Advance by frame by pressing square"
                            ToolTipService.InitialShowDelay="100">
                            <TextBlock Text="i"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="10" />
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                        <CheckBox Content="Unlock Fps"
                                  IsChecked="{Binding IsDbgFpsEnabled}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,20,0" />
                        <xctk:DoubleUpDown x:Name="FpsUpDown"
                                           Value="{Binding Fps}"
                                           TextAlignment="Center"
                                           Width="80"
                                           Minimum="5"
                                           Maximum="140"
                                           Increment="1"
                                           FormatString="F0"
                                           IsEnabled="{Binding IsDbgFpsEnabled}"
                                           BorderBrush="#3F3F46" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2" Margin="0,0,0,5">
            <TabItem Header="No Clip / Camera">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderThickness="1"
                            BorderBrush="#333"
                            CornerRadius="3"
                            Margin="0,0,10,0"
                            Padding="10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="No Clip"
                                          IsChecked="{Binding IsNoClipEnabled}"
                                          IsEnabled="{Binding AreOptionsEnabled}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0" />
                                <Border
                                    Background="#3498db"
                                    CornerRadius="10"
                                    Width="12"
                                    Height="12"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="Vertical movement with Ctrl/Space or L2/R2 on controller"
                                    ToolTipService.InitialShowDelay="100">
                                    <TextBlock Text="i"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="10" />
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <xctk:DoubleUpDown
                                                   Value="{Binding NoClipSpeedScale}"
                                                   TextAlignment="Center"
                                                   Width="80"
                                                   Minimum="0.05"
                                                   Maximum="5.0"
                                                   Increment="0.50"
                                                   FormatString="F2"
                                                   IsEnabled="{Binding IsNoClipEnabled}"
                                                   BorderBrush="#3F3F46" />
                                <TextBlock Text="Speed" VerticalAlignment="Center" Margin="5,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            BorderThickness="1"
                            BorderBrush="#333"
                            CornerRadius="3"
                            Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <CheckBox Content="Free Cam"
                                              IsChecked="{Binding IsFreeCamEnabled}"
                                              IsEnabled="{Binding AreOptionsEnabled}"
                                              VerticalAlignment="Center" />
                                    <Border
                                        Background="#3498db"
                                        CornerRadius="10"
                                        Width="12"
                                        Height="12"
                                        Margin="5,0,10,0"
                                        VerticalAlignment="Center"
                                        ToolTip="Only works with controller for now"
                                        ToolTipService.InitialShowDelay="100">
                                        <TextBlock Text="i"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="10" />
                                    </Border>
                                </StackPanel>

                                <CheckBox Content="Player Movement"
                                          IsChecked="{Binding IsPlayerMovementEnabled}"
                                          Margin="0,0,0,5"
                                          VerticalAlignment="Center">
                                    <CheckBox.IsEnabled>
                                        <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                            <Binding Path="AreOptionsEnabled" />
                                            <Binding Path="IsFreeCamEnabled" />
                                        </MultiBinding>
                                    </CheckBox.IsEnabled>
                                </CheckBox>

                                <Button Content="Move Free Cam to Player"
                                        Command="{Binding MoveCamToPlayerCommand}"
                                        IsEnabled="{Binding IsFreeCamEnabled}"
                                        Padding="5,0"
                                        Margin="0,0,0,5"
                                        HorizontalAlignment="Left" />
                                <Button Content="Move Player to Free Cam"
                                        Command="{Binding MovePlayerToCamCommand}"
                                        IsEnabled="{Binding IsFreeCamEnabled}"
                                        Padding="5,0"
                                        Margin="0,0,0,5"
                                        HorizontalAlignment="Left" />

                                <CheckBox Content="Death Cam"
                                          IsChecked="{Binding IsDeathCamEnabled}"
                                          IsEnabled="{Binding AreOptionsEnabled}"
                                          VerticalAlignment="Center"
                                          Margin="0,5,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <CheckBox Content="Increase Camera Vertical limits"
                                          VerticalAlignment="Center"
                                          IsEnabled="{Binding IsFreeCamEnabled, Converter={StaticResource InverseBooleanConverter}}"
                                          IsChecked="{Binding IsCamVertIncreaseEnabled}"
                                          Margin="0,0,0,15" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                            IsEnabled="{Binding IsFreeCamEnabled, Converter={StaticResource InverseBooleanConverter}}">
                                    <xctk:DoubleUpDown x:Name="FovUpDown"
                                                       Value="{Binding CameraFov}"
                                                       TextAlignment="Center"
                                                       Width="80"
                                                       Minimum="5"
                                                       Maximum="140"
                                                       Increment="1"
                                                       FormatString="F1"
                                                       IsEnabled="{Binding AreOptionsEnabled}"
                                                       BorderBrush="#3F3F46" />
                                    <TextBlock Text="Field of View" VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>

                                <Button Content="Set Default FOV"
                                        Command="{Binding SetDefaultFovCommand}"
                                        HorizontalAlignment="Right"
                                        Padding="5,2"
                                        Margin="0,0,0,0"
                                        Width="100">
                                    <Button.IsEnabled>
                                        <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                            <Binding Path="AreOptionsEnabled" />
                                            <Binding Path="IsFreeCamEnabled"
                                                     Converter="{StaticResource InverseBooleanConverter}" />
                                        </MultiBinding>
                                    </Button.IsEnabled>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,5">
            <StackPanel Margin="10">
                <TextBlock Text="Rendering" />

                <Grid Margin="10,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <CheckBox Content="Hitbox View"
                              IsChecked="{Binding IsHitboxEnabled}"
                              Grid.Column="0" Grid.Row="0"
                              Margin="0,2,15,2" />

                    <CheckBox Content="Player Sound View"
                              IsChecked="{Binding IsSoundViewEnabled}"
                              Grid.Column="0" Grid.Row="1"
                              Margin="0,2,15,2" />

                    <CheckBox Content="Collision Mesh 1"
                              IsChecked="{Binding IsDrawLowHitEnabled}"
                              Grid.Column="1" Grid.Row="0"
                              Margin="0,2,15,2" />

                    <CheckBox Content="Collision Mesh 2"
                              IsChecked="{Binding IsDrawHighHitEnabled}"
                              Grid.Column="1" Grid.Row="1"
                              Margin="0,2,15,2" />

                    <CheckBox Content="Character Mesh"
                              IsChecked="{Binding IsDrawChrRagdollEnabled}"
                              Grid.Column="1" Grid.Row="2"
                              Margin="0,2,15,2" />

                    <CheckBox Content="Hide Map"
                              IsChecked="{Binding IsHideMapEnabled}"
                              Grid.Column="2" Grid.Row="0"
                              Margin="0,2" />

                    <CheckBox Content="Hide Objects"
                              IsChecked="{Binding IsHideObjectsEnabled}"
                              Grid.Column="2" Grid.Row="1"
                              Margin="0,2" />

                    <CheckBox Content="Hide Characters"
                              IsChecked="{Binding IsHideCharactersEnabled}"
                              Grid.Column="2" Grid.Row="2"
                              Margin="0,2" />

                    <CheckBox Content="Hide Sfx"
                              IsChecked="{Binding IsHideSfxEnabled}"
                              Grid.Column="2" Grid.Row="3"
                              Margin="0,2" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,5">
            <TabControl Padding="10">
                <TabItem Header="Menus">
                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="Travel"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding TravelCommand}"
                                Width="80"
                                Height="24"
                                Margin="3" />

                        <Button Content="Level Up"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding LevelUpCommand}"
                                Width="80"
                                Height="24"
                                Margin="3" />

                        <Button Content="Upgrade"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding ReinforceWeaponCommand}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Repair"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding RepairCommand}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Infuse"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding InfuseWeaponCommand}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Allot Estus"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Height="24"
                                Command="{Binding AllotEstusCommand}"
                                Width="80"
                                Margin="3" />

                        <Button Content="Attunement"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Height="24"
                                Command="{Binding AttunementCommand}"
                                Width="80"
                                Margin="3" />
                    </WrapPanel>
                </TabItem>

                <TabItem Header="Shops">
                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="Handmaid"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding OpenShopCommand}"
                                CommandParameter="{x:Static gameIds:ShopParams.ShrineMaiden}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Greirat"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding OpenShopCommand}"
                                CommandParameter="{x:Static gameIds:ShopParams.Greirat}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Patches"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding OpenShopCommand}"
                                CommandParameter="{x:Static gameIds:ShopParams.Patches}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Orbeck"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding OpenShopCommand}"
                                CommandParameter="{x:Static gameIds:ShopParams.Orbeck}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Cornyx"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding OpenShopCommand}"
                                CommandParameter="{x:Static gameIds:ShopParams.Cornyx}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Karla"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding OpenShopCommand}"
                                CommandParameter="{x:Static gameIds:ShopParams.Karla}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <Button Content="Transpose"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Command="{Binding OpenShopCommand}"
                                CommandParameter="{x:Static gameIds:ShopParams.Transpose}"
                                Height="24"
                                Width="80"
                                Margin="3" />

                        <CheckBox Content="Access full shop lineup"
                                  IsChecked="{Binding IsFullLineUpEnabled}"
                                  VerticalAlignment="Center"
                                  Height="24"
                                  Width="160"
                                  Margin="3" />
                    </WrapPanel>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
