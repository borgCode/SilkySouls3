<UserControl x:Class="SilkySouls3.Views.EventTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:SilkySouls3.Converters"
             xmlns:gameIds="clr-namespace:SilkySouls3.GameIds"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="500">

    <UserControl.Resources>
        <converters:BooleanAndConverter x:Key="BooleanAndConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,10">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Event Flags"
                               FontWeight="Bold" />

                    <Border Background="#3498db"
                            CornerRadius="10"
                            Width="12"
                            Height="12"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Get or set event by Event ID"
                            ToolTipService.InitialShowDelay='100'>
                        <TextBlock Text="i"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="10" />
                    </Border>
                </StackPanel>

                <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                </Grid>

                <StackPanel Orientation="Horizontal" Margin="10,10,0,0">
                    <TextBlock Text="Event ID:" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox Width="100" Text="{Binding GetFlagId}" Margin="0,0,10,0" />

                    <Button Content="Get Event"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Padding="10,3"
                            Margin="10,0,0,0"
                            Command="{Binding GetEventCommand}" />

                    <TextBlock Text="State:" VerticalAlignment="Center" Margin="10,0,5,0" />
                    <TextBlock Text="{Binding EventStatusText}"
                               Foreground="{Binding EventStatusColor}"
                               VerticalAlignment="Center" Margin="5,0,10,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="10,10,0,0">
                    <TextBlock Text="Event ID:" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox Width="100" Text="{Binding SetFlagId}" Margin="0,0,10,0" />

                    <ComboBox Width="70" SelectedIndex="{Binding FlagStateIndex}" Margin="0,0,10,0">
                        <ComboBoxItem Content="ON" />
                        <ComboBoxItem Content="OFF" />
                    </ComboBox>

                    <Button Content="Set Event"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Padding="10,3"
                            Margin="10,0,0,0"
                            Command="{Binding SetFlagCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="Game Progression"
                           FontWeight="Bold"
                           Margin="0,0,0,10" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button x:Name="UnlockMidirButton" Content="Unlock Midir"
                            Command="{Binding UnlockMidirCommand}"
                            Height="20"
                            Margin="0,5">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                <Binding Path="AreOptionsEnabled" />
                                <Binding Path="IsDlc2Available" />
                            </MultiBinding>
                        </Button.IsEnabled>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,0">
            <StackPanel Margin="10">
                <TextBlock Text="Move to Firelink"
                           FontWeight="Bold"
                           Margin="0,0,0,10" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="0"
                            Content="Patches to Firelink"
                            Command="{Binding MovePatchesToFirelinkCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Height="20"
                            Margin="0,5,5,5" />

                    <Button Grid.Row="0" Grid.Column="1"
                            Content="Greirat to Firelink"
                            Command="{Binding MoveToFirelinkCommand}"
                            CommandParameter="{x:Static gameIds:EventFlag.Greirat}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Height="20"
                            Margin="5,5,0,5" />

                    <Button Grid.Row="1" Grid.Column="0"
                            Content="Karla to Firelink"
                            Command="{Binding MoveToFirelinkCommand}"
                            CommandParameter="{x:Static gameIds:EventFlag.Karla}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Height="20"
                            Margin="0,5,5,5" />

                    <Button Grid.Row="1" Grid.Column="1"
                            Content="Cornyx to Firelink"
                            Command="{Binding MoveToFirelinkCommand}"
                            CommandParameter="{x:Static gameIds:EventFlag.Cornyx}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Height="20"
                            Margin="5,5,0,5" />

                    <Button Grid.Row="2" Grid.Column="0"
                            Content="Irina to Firelink"
                            Command="{Binding MoveToFirelinkCommand}"
                            CommandParameter="{x:Static gameIds:EventFlag.Irina}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Height="20"
                            Margin="0,5,5,5" />

                    <Button Grid.Row="2" Grid.Column="1"
                            Content="Orbeck to Firelink"
                            Command="{Binding MoveToFirelinkCommand}"
                            CommandParameter="{x:Static gameIds:EventFlag.Orbeck}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Height="20"
                            Margin="5,5,0,5" />
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="3"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,10,0,0">

            <StackPanel Margin="10">
                <CheckBox Content="Disable Events"
                          IsChecked="{Binding IsDisableEventsEnabled}"
                          VerticalAlignment="Center"
                          Margin="0,0,20,0" />
                <CheckBox Content="Draw Events"
                          IsChecked="{Binding IsDrawEventsEnabled}"
                          VerticalAlignment="Center"
                          Margin="0,5,20,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>