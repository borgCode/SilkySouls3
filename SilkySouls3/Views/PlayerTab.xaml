<UserControl x:Class="SilkySouls3.Views.PlayerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:converters="clr-namespace:SilkySouls3.Converters"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <converters:BooleanAndConverter x:Key="BooleanAndConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Health:" Grid.Column="0" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="5,0,0,0">
                    <xctk:IntegerUpDown x:Name="HealthUpDown"
                                        Value="{Binding CurrentHp}"
                                        TextAlignment="Center"
                                        Width="100"
                                        IsEnabled="{Binding AreOptionsEnabled}"
                                        BorderBrush="#3F3F46" />
                    <TextBlock Text="{Binding CurrentMaxHp, StringFormat=Max: {0}}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0" />
                    <Button
                        Content="RTSR"
                        Command="{Binding SetRtsrCommand}"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="10,0,0,0"
                        Width="60"
                        Height="30" />
                    <Button
                        Content="Max Hp"
                        Command="{Binding SetMaxHpCommand}"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="10,0,0,0"
                        Width="60"
                        Height="30" />
                    <Button
                        Content="Die"
                        Command="{Binding DieCommand}"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="10,0,0,0"
                        Width="35"
                        Height="30" />
                    <TextBox Width="60"
                             Height="30"
                             Margin="10,0,0,0"
                             Padding="2,0"
                             VerticalContentAlignment="Center"
                             TextAlignment="Center"
                             Text="{Binding CustomHp, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding AreOptionsEnabled}"
                             MaxLength="4"
                             ToolTip="Absolute (e.g. 545) or percentage (e.g. 40%)"
                             ToolTipService.InitialShowDelay="100" />
                    <Button Content="Set Custom Hp"
                            Command="{Binding SetCustomHpCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Margin="5,0,0,0"
                            Width="100"
                            Height="30" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Margin="0,10,0,10" BorderThickness="1" BorderBrush="#333" CornerRadius="3">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <UniformGrid Grid.Row="0" Grid.Column="0" Rows="1" Columns="2">
                        <Button Content="Save Pos 1"
                                Command="{Binding SavePositionCommand}" CommandParameter="0"
                                Margin="0,0,5,5"
                                IsEnabled="{Binding AreOptionsEnabled}" />

                        <Button Content="Restore Pos 1"
                                Command="{Binding RestorePositionCommand}" CommandParameter="0"
                                Margin="5,0,0,5">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="AreOptionsEnabled" />
                                    <Binding Path="IsPos1Saved" />
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                    </UniformGrid>

                    <StackPanel Grid.Row="0" Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10,0,0,5">

                        <CheckBox Content="Include State"
                                  IsChecked="{Binding IsStateIncluded}" />

                        <Border Background="#3498db"
                                CornerRadius="10"
                                Width="12"
                                Height="12"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="Remembers HP/FP/Stamina when saving position"
                                ToolTipService.InitialShowDelay='100'>
                            <TextBlock Text="i"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="10" />
                        </Border>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Grid.Column="0" Rows="1" Columns="2">
                        <Button Content="Save Pos 2"
                                Command="{Binding SavePositionCommand}" CommandParameter="1"
                                Margin="0,5,5,0"
                                IsEnabled="{Binding AreOptionsEnabled}" />

                        <Button Content="Restore Pos 2"
                                Command="{Binding RestorePositionCommand}" CommandParameter="1"
                                Margin="5,5,0,0">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="AreOptionsEnabled" />
                                    <Binding Path="IsPos2Saved" />
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                    </UniformGrid>

                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,5,0,0"
                                HorizontalAlignment="Left">
                        <xctk:DoubleUpDown Width="70" Margin="5,0,0,0"
                                           Padding="0,0,5,0"
                                           Value="{Binding PosX}" FormatString="F1"
                                           IsEnabled="False" />
                        <xctk:DoubleUpDown Width="70" Margin="5,0,5,0"
                                           Padding="0,0,5,0"
                                           Value="{Binding PosY}" FormatString="F1"
                                           IsEnabled="False" />
                        <xctk:DoubleUpDown Width="70" Value="{Binding PosZ}"
                                           Padding="0,0,5,0"
                                           FormatString="F1"
                                           IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <CheckBox Content="No Death"
                              IsChecked="{Binding IsNoDeathEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="No Damage"
                              IsChecked="{Binding IsNoDamageEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="Infinite Stamina"
                              IsChecked="{Binding IsInfiniteStaminaEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="No Goods Consume"
                              IsChecked="{Binding IsNoGoodsConsumeEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="Infinite FP"
                              IsChecked="{Binding IsInfiniteFpEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="Infinite Durability"
                              IsChecked="{Binding IsInfiniteDurabilityEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="One Shot"
                              IsChecked="{Binding IsOneShotEnabled}"
                              Margin="0,2" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <CheckBox Content="Invisible"
                              IsChecked="{Binding IsInvisibleEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="Silent"
                              IsChecked="{Binding IsSilentEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="No Ammo Consume"
                              IsChecked="{Binding IsNoAmmoConsumeEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="Infinite Poise"
                              IsChecked="{Binding IsInfinitePoiseEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="No Hit"
                              IsChecked="{Binding IsNoHitEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="Heal Over Time"
                              IsChecked="{Binding IsHotEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="FP Regen"
                              IsChecked="{Binding IsFpRegenEnabled}"
                              Margin="0,2" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <CheckBox Content="Disable Roll"
                              IsChecked="{Binding IsNoRollEnabled}"
                              Margin="0,2" />
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="3" Text="{Binding SoulLevel, StringFormat='Soul Level: {0}'}" FontWeight="Bold"
                       Margin="0,0,0,5" />

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="VigorUpDown"
                                            Value="{Binding Vigor}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46"
                                            Tag="Vigor" />
                        <TextBlock Text="Vigor" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="AttunementUpDown"
                                            Value="{Binding Attunement}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Attunement"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Attunement" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="EnduranceUpDown"
                                            Value="{Binding Endurance}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Endurance"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Endurance" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="StrengthUpDown"
                                            Value="{Binding Strength}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Strength"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Strength" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="DexterityUpDown"
                                            Value="{Binding Dexterity}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Dexterity"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Dexterity" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="IntelligenceUpDown"
                                            Value="{Binding Intelligence}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Intelligence"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Intelligence" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="FaithUpDown"
                                            Value="{Binding Faith}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Faith"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Faith" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="LuckUpDown"
                                            Value="{Binding Luck}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Luck"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Luck" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="VitalityUpDown"
                                            Value="{Binding Vitality}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Vitality"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Vitality" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="SoulsUpDown"
                                            Value="{Binding Souls}"
                                            TextAlignment="Center"
                                            Width="120"
                                            Minimum="0"
                                            Maximum="999999999"
                                            Grid.Column="0"
                                            Tag="Souls"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="Souls" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="15,0,0,0">
                    <Button Content="Ember"
                            Height="25" Width="130"
                            FontSize="14"
                            Command="{Binding EmberCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Margin="0,0,0,10" />
                    <Button Content="Rest"
                            Height="25" Width="130"
                            FontSize="14"
                            Command="{Binding RestCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Margin="0,0,0,10" />
                    <Button Content="Give 10k Souls"
                            Command="{Binding GiveSoulsCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Width="130"
                            Height="25" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="5" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Margin="0,2" VerticalAlignment="Center">
                    <xctk:DoubleUpDown x:Name="SpeedUpDown"
                                       Value="{Binding PlayerSpeed}"
                                       TextAlignment="Center"
                                       Width="80"
                                       Minimum="0"
                                       Maximum="10"
                                       Increment="0.50"
                                       FormatString="F2"
                                       IsEnabled="{Binding AreOptionsEnabled}"
                                       BorderBrush="#3F3F46" />
                    <TextBlock Text="Player Speed" VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Margin="0,2" VerticalAlignment="Center">
                    <xctk:IntegerUpDown x:Name="NewGameUpDown"
                                        Value="{Binding NewGame}"
                                        TextAlignment="Center"
                                        Width="80"
                                        Minimum="0"
                                        Maximum="7"
                                        IsEnabled="{Binding AreOptionsEnabled}"
                                        BorderBrush="#3F3F46" />
                    <TextBlock Text="New Game" VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Margin="15,2,0,0" VerticalAlignment="Center">
                    <CheckBox Content="Remember"
                              IsChecked="{Binding IsRememberSpeedEnabled}"
                              VerticalAlignment="Center" />
                    <Border Background="#3498db"
                            CornerRadius="10"
                            Width="12" Height="12"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Persist non-default player speed across sessions"
                            ToolTipService.InitialShowDelay="100">
                        <TextBlock Text="i" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="10" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="15,2,0,0" VerticalAlignment="Center">
                    <CheckBox Content="Auto NG+7"
                              IsChecked="{Binding IsAutoSetNewGameSevenEnabled}"
                              VerticalAlignment="Center" />
                    <Border Background="#3498db"
                            CornerRadius="10"
                            Width="12" Height="12"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Automatically sets the game to New Game+7 when starting a new game"
                            ToolTipService.InitialShowDelay='100'>
                        <TextBlock Text="i" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="10" />
                    </Border>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                            Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Current Animation:" Margin="0,0,0,4"   />
                    <TextBlock Text="{Binding CurrentAnimation}" Foreground="Gold" />
                </StackPanel>
            </Grid>
            <Border Grid.Row="6" BorderThickness="1" BorderBrush="#333" CornerRadius="3" Margin="0,10,0,0">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Special Effect" FontWeight="Bold" Margin="0,0,0,5" />
                        <StackPanel Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBox Text="{Binding ApplySpEffectInput, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" Height="25" Padding="2,0"
                                         TextAlignment="Center" VerticalContentAlignment="Center"
                                         IsEnabled="{Binding AreOptionsEnabled}" />
                                <Button Content="Apply"
                                        Command="{Binding ApplySpEffectCommand}"
                                        IsEnabled="{Binding AreOptionsEnabled}"
                                        Width="60" Height="25" Margin="15,0,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBox Text="{Binding RemoveSpEffectInput, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" Height="25" Padding="2,0"
                                         TextAlignment="Center" VerticalContentAlignment="Center"
                                         IsEnabled="{Binding AreOptionsEnabled}" />
                                <Button Content="Remove"
                                        Command="{Binding RemoveSpEffectCommand}"
                                        IsEnabled="{Binding AreOptionsEnabled}"
                                        Width="60" Height="25" Margin="15,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox Grid.Column="1" Content="Show Active Special Effects"
                              IsChecked="{Binding IsShowActiveSpEffectsEnabled}"
                              Margin="15,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
